// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ENUMS

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum ProductVisibility {
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

// USER & AUTH

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     Boolean   @default(false)
  emailVerifyToken  String?   @unique
  passwordHash      String
  role              Role      @default(CUSTOMER)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  profile           UserProfile?
  addresses         Address[]
  orders            Order[]
  cart              Cart?
  passwordResets    PasswordReset[]
  refreshTokens     RefreshToken[]
  sessions          Session[]

  @@index([email])
  @@map("users")
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firstName   String
  lastName    String
  phone       String?
  avatarUrl   String?
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_resets")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("refresh_tokens")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ADDRESS

model Address {
  id           String   @id @default(cuid())
  userId       String
  label        String?  // e.g. "Home", "Office"
  recipientName String
  phone        String
  street       String
  city         String
  province     String
  postalCode   String
  country      String   @default("ID")
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([userId])
  @@map("addresses")
}

// CATEGORY

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  position    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    ProductCategory[]

  // SEO
  metaTitle       String?
  metaDescription String?

  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

// PRODUCT

model Product {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  description     String?
  specifications  Json?             // Flexible key-value specs
  visibility      ProductVisibility @default(UNPUBLISHED)
  isFeatured      Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  // SEO
  metaTitle       String?
  metaDescription String?
  openGraphTitle  String?
  openGraphDesc   String?
  openGraphImage  String?
  schemaMarkup    Json?

  categories      ProductCategory[]
  images          ProductImage[]
  variants        ProductVariant[]
  attributes      ProductAttribute[]
  cartItems       CartItem[]
  orderItems      OrderItem[]

  @@index([slug])
  @@index([visibility])
  @@index([isFeatured])
  @@map("products")
}

model ProductCategory {
  productId   String
  categoryId  String

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_categories")
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  url        String
  altText    String?
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// Attribute types (e.g. "Color", "Size")
model AttributeType {
  id         String            @id @default(cuid())
  name       String            @unique  // e.g. "Color"
  createdAt  DateTime          @default(now())

  values     AttributeValue[]

  @@map("attribute_types")
}

// Attribute values (e.g. "Red", "XL")
model AttributeValue {
  id              String         @id @default(cuid())
  attributeTypeId String
  value           String         // e.g. "Red"

  attributeType   AttributeType  @relation(fields: [attributeTypeId], references: [id], onDelete: Cascade)
  variantOptions  VariantOption[]
  productAttributes ProductAttribute[]

  @@unique([attributeTypeId, value])
  @@map("attribute_values")
}

// Which attribute types apply to a product (for filtering)
model ProductAttribute {
  id               String         @id @default(cuid())
  productId        String
  attributeValueId String

  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeValueId])
  @@map("product_attributes")
}

// A SKU — one purchasable unit (e.g. Red + XL)
model ProductVariant {
  id          String      @id @default(cuid())
  productId   String
  sku         String      @unique
  price       Decimal     @db.Decimal(12, 2)
  comparePrice Decimal?   @db.Decimal(12, 2)  // Original price for discount display
  stock       Int         @default(0)
  stockStatus StockStatus @default(OUT_OF_STOCK)
  weight      Decimal?    @db.Decimal(8, 3)   // kg
  imageUrl    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  options     VariantOption[]
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

// Links a variant to its attribute values
model VariantOption {
  variantId        String
  attributeValueId String

  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([variantId, attributeValueId])
  @@map("variant_options")
}

// CART

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@map("carts")
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  productId String
  variantId String
  quantity  Int
  addedAt   DateTime       @default(now())

  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

// SHIPPING

model Courier {
  id          String   @id @default(cuid())
  name        String   // e.g. "JNE", "SiCepat"
  code        String   @unique
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  shipments   Shipment[]

  @@map("couriers")
}

model Shipment {
  id              String   @id @default(cuid())
  orderId         String   @unique
  courierId       String
  service         String   // e.g. "REG", "YES"
  trackingNumber  String?
  shippingCost    Decimal  @db.Decimal(12, 2)
  estimatedDays   Int?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  order           Order    @relation(fields: [orderId], references: [id])
  courier         Courier  @relation(fields: [courierId], references: [id])

  @@map("shipments")
}

// ORDER

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique  // Human-readable, e.g. "ORD-20240501-001"
  userId          String
  addressId       String
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  subtotal        Decimal       @db.Decimal(12, 2)
  shippingCost    Decimal       @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  notes           String?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  address         Address       @relation(fields: [addressId], references: [id])
  items           OrderItem[]
  payment         Payment?
  shipment        Shipment?
  statusHistory   OrderStatusHistory[]
  invoice         Invoice?

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id          String         @id @default(cuid())
  orderId     String
  productId   String
  variantId   String
  productName String         // Snapshot at time of order
  variantSku  String
  quantity    Int
  unitPrice   Decimal        @db.Decimal(12, 2)
  subtotal    Decimal        @db.Decimal(12, 2)

  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product        @relation(fields: [productId], references: [id])
  variant     ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  changedAt DateTime    @default(now())
  changedBy String?     // Admin user ID or "system"

  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

// PAYMENT

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  method          String        // e.g. "bank_transfer", "credit_card", "e-wallet"
  provider        String?       // e.g. "midtrans", "xendit"
  externalId      String?       @unique  // Payment gateway transaction ID
  amount          Decimal       @db.Decimal(12, 2)
  status          PaymentStatus @default(UNPAID)
  paidAt          DateTime?
  refundedAt      DateTime?
  metadata        Json?         // Gateway-specific data
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order           Order         @relation(fields: [orderId], references: [id])

  @@index([externalId])
  @@map("payments")
}

// INVOICE

model Invoice {
  id            String   @id @default(cuid())
  orderId       String   @unique
  invoiceNumber String   @unique
  issuedAt      DateTime @default(now())
  fileUrl       String?  // PDF stored in CDN/object storage

  order         Order    @relation(fields: [orderId], references: [id])

  @@map("invoices")
}

// MEDIA / ASSETS

model Media {
  id          String   @id @default(cuid())
  filename    String
  url         String
  mimeType    String
  size        Int      // bytes
  width       Int?
  height      Int?
  uploadedBy  String?  // Admin user ID
  createdAt   DateTime @default(now())

  @@map("media")
}

// ANALYTICS & REPORTING

// Aggregated daily sales snapshot for fast report queries
model DailySalesSnapshot {
  id            String   @id @default(cuid())
  date          DateTime @db.Date
  totalOrders   Int
  totalRevenue  Decimal  @db.Decimal(14, 2)
  totalItems    Int
  newCustomers  Int

  @@unique([date])
  @@map("daily_sales_snapshots")
}

// Per-product daily sales for product-level analytics
model ProductSalesSnapshot {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  productId   String
  unitsSold   Int
  revenue     Decimal  @db.Decimal(14, 2)

  @@unique([date, productId])
  @@index([productId])
  @@map("product_sales_snapshots")
}

// SEO / SITEMAP

model SitemapEntry {
  id         String   @id @default(cuid())
  url        String   @unique
  changefreq String   @default("weekly")  // always, hourly, daily, weekly, etc.
  priority   Decimal  @default(0.5) @db.Decimal(2, 1)
  lastmod    DateTime @default(now())

  @@map("sitemap_entries")
}

// RATE LIMITING (API protection — can also be handled in Redis)

model RateLimitRecord {
  id        String   @id @default(cuid())
  key       String   // e.g. "ip:192.168.1.1:login"
  hits      Int      @default(1)
  windowEnd DateTime

  @@unique([key])
  @@index([windowEnd])
  @@map("rate_limit_records")
}